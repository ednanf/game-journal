{
  "extends": "@tsconfig/node22/tsconfig.json",
  "module": "NodeNext",
  "allowJs": true,
  "checkJs": true,
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}